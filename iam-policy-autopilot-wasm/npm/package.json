{
  "name": "iam-policy-autopilot-wasm",
  "version": "0.1.4",
  "description": "Analyze source code and generate least-privilege IAM policies entirely in the browser via WebAssembly.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awslabs/iam-policy-autopilot",
    "directory": "iam-policy-autopilot-wasm/npm"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./extractor": {
      "import": "./dist/extractor.js",
      "types": "./dist/extractor.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bash ../build.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ast-grep/wasm": "^0.42.0",
    "web-tree-sitter": "^0.26.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-typescript": "0.23.2",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "tree-sitter-go": ">=0.25.0",
    "tree-sitter-javascript": ">=0.25.0",
    "tree-sitter-python": ">=0.25.0",
    "tree-sitter-typescript": ">=0.23.2"
  },
  "peerDependenciesMeta": {
    "tree-sitter-go": {
      "optional": true
    },
    "tree-sitter-javascript": {
      "optional": true
    },
    "tree-sitter-python": {
      "optional": true
    },
    "tree-sitter-typescript": {
      "optional": true
    }
  }
}